{
  "name": "kingz-iptv",
  "version": "1.0.0",
  "description": "KINGZ IPTV desktop",
  "main": "main.js",
  "author": "KINGZ IPTV",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kingz.iptv",
    "productName": "KINGZ IPTV",
    "files": ["main.js"],
    "directories": { "buildResources": "build" },
    "win": { "target": "nsis", "icon": "build/icon.png" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true },
    "mac": { "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }], "icon": "build/icon.png", "category": "public.app-category.entertainment", "identity": null },
    "linux": { "target": "AppImage", "icon": "build/icon.png", "category": "AudioVideo" }
  }
}
